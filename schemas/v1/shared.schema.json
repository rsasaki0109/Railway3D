{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://railway3d.dev/schemas/v1/shared.schema.json",
  "title": "Railway3D Shared Schema Definitions",
  "$defs": {
    "entityId": {
      "type": "string",
      "pattern": "^r3d:[a-z0-9-]+:[a-z0-9-]+:[a-z0-9-]+:[A-Za-z0-9._:-]+$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "datasetId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "localizedText": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "lngLat": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        }
      ],
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "bbox": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        }
      ],
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    },
    "verticalDatum": {
      "type": "string",
      "enum": [
        "JGD2024_ORTHOMETRIC",
        "JGD2011_ORTHOMETRIC",
        "WGS84_ELLIPSOIDAL",
        "EGM2008_ORTHOMETRIC",
        "LOCAL_ENGINEERING_DATUM",
        "UNKNOWN"
      ]
    },
    "knownVerticalDatum": {
      "type": "string",
      "enum": [
        "JGD2024_ORTHOMETRIC",
        "JGD2011_ORTHOMETRIC",
        "WGS84_ELLIPSOIDAL",
        "EGM2008_ORTHOMETRIC",
        "LOCAL_ENGINEERING_DATUM"
      ]
    },
    "measurementMethod": {
      "type": "string",
      "enum": [
        "surveyed",
        "official_longitudinal_profile",
        "operator_published",
        "government_open_data",
        "community_verified",
        "dem_sampled",
        "constraint_solved",
        "interpolated",
        "digitized",
        "unknown"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["unknown", "low", "medium", "high", "verified"]
    },
    "qualityFlag": {
      "type": "string",
      "enum": [
        "MISSING_RAIL_ELEVATION",
        "MISSING_GROUND_ELEVATION",
        "VERTICAL_DATUM_UNKNOWN",
        "LONG_INTERPOLATION_SPAN",
        "DEM_VOID",
        "DEM_SEAM",
        "STATION_SNAP_OUTLIER",
        "STRUCTURE_CLEARANCE_CONFLICT",
        "GRADIENT_OUTLIER",
        "SOURCE_CONFLICT",
        "TEMPORAL_MISMATCH",
        "MANUAL_REVIEW_REQUIRED"
      ]
    },
    "structureType": {
      "type": "string",
      "enum": [
        "underground_tunnel",
        "cut_and_cover_tunnel",
        "mountain_tunnel",
        "undersea_tunnel",
        "station_box",
        "surface",
        "cutting",
        "embankment",
        "viaduct",
        "bridge",
        "at_grade_crossing",
        "depot",
        "unknown"
      ]
    },
    "serviceStatus": {
      "type": "string",
      "enum": ["operational", "under_construction", "planned", "suspended", "closed", "historic"]
    },
    "provenanceRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceId": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/sourceId"
        },
        "method": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/measurementMethod"
        },
        "sourceFeatureId": {
          "type": "string"
        },
        "pageOrSection": {
          "type": "string"
        },
        "operatorNote": {
          "type": "string"
        }
      },
      "required": ["sourceId", "method"]
    },
    "measurementMeta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/measurementMethod"
        },
        "confidence": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/confidence"
        },
        "uncertaintyM": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "type": "array",
          "items": {
            "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/provenanceRef"
          }
        },
        "flags": {
          "type": "array",
          "items": {
            "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/qualityFlag"
          }
        },
        "reviewedBy": {
          "type": "string"
        },
        "reviewedAt": {
          "type": "string"
        }
      },
      "required": ["method", "confidence", "provenance", "flags"],
      "allOf": [
        {
          "if": {
            "properties": {
              "method": {
                "enum": [
                  "surveyed",
                  "official_longitudinal_profile",
                  "operator_published",
                  "government_open_data",
                  "community_verified"
                ]
              }
            },
            "required": ["method"]
          },
          "then": {
            "properties": {
              "provenance": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "confidence": {
                "enum": ["high", "verified"]
              }
            },
            "required": ["confidence"]
          },
          "then": {
            "properties": {
              "provenance": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "elevationValue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueM": {
          "type": "number"
        },
        "verticalDatum": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/knownVerticalDatum"
        },
        "method": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/measurementMethod"
        },
        "confidence": {
          "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/confidence"
        },
        "uncertaintyM": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "type": "array",
          "items": {
            "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/provenanceRef"
          }
        },
        "flags": {
          "type": "array",
          "items": {
            "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/qualityFlag"
          }
        }
      },
      "required": ["valueM", "verticalDatum", "method", "confidence", "provenance", "flags"],
      "allOf": [
        {
          "if": {
            "properties": {
              "confidence": {
                "enum": ["high", "verified"]
              }
            },
            "required": ["confidence"]
          },
          "then": {
            "properties": {
              "provenance": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "lineStringGeometry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/lngLat"
          }
        }
      },
      "required": ["type", "coordinates"]
    }
  }
}
