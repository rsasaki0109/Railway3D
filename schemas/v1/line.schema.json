{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://railway3d.dev/schemas/v1/line.schema.json",
  "title": "RailwayLine",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/entityId"
    },
    "operatorIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/entityId"
      }
    },
    "name": {
      "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/localizedText"
    },
    "publicCode": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "textColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "routeIds": {
      "type": "array",
      "items": {
        "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/entityId"
      }
    },
    "serviceStatus": {
      "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/serviceStatus"
    },
    "validFrom": {
      "type": "string"
    },
    "validTo": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/provenanceRef"
      }
    }
  },
  "required": ["id", "operatorIds", "name", "routeIds", "serviceStatus", "sourceRefs"]
}
