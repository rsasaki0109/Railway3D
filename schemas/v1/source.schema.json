{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://railway3d.dev/schemas/v1/source.schema.json",
  "title": "Railway3DDataSource",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/sourceId"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "SPDX": {
          "type": "string"
        },
        "attributionRequired": {
          "type": "boolean"
        },
        "shareAlike": {
          "type": "boolean"
        },
        "commercialUseAllowed": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "const": "unknown"
            }
          ]
        },
        "redistributionAllowed": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "const": "unknown"
            }
          ]
        },
        "notice": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "attributionRequired",
        "shareAlike",
        "commercialUseAllowed",
        "redistributionAllowed",
        "notice"
      ]
    },
    "retrievedAt": {
      "type": "string"
    },
    "sourceValidAt": {
      "type": "string"
    },
    "checksum": {
      "$ref": "https://railway3d.dev/schemas/v1/shared.schema.json#/$defs/sha256"
    },
    "sourceLocator": {
      "type": "string"
    },
    "citationText": {
      "type": "string",
      "minLength": 1
    },
    "processingNotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["id", "title", "publisher", "license", "retrievedAt", "citationText"]
}
